---
import BaseLayout from '../layouts/BaseLayout.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sepi Reissmueller',
  jobTitle: 'ER Nurse & AHA BLS/ACLS Instructor',
  worksFor: {
    '@type': 'Organization',
    name: 'UC Irvine Medical Center',
  },
  knowsAbout: [
    'Basic Life Support',
    'Advanced Cardiovascular Life Support',
    'CPR',
    'AED',
    'Emergency Nursing',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Orange County BLS Training',
  url: 'https://ocblstraining.github.io',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is this an official AHA course?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. These are official American Heart Association courses. You receive an AHA eCard on completion.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does certification last?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '2 years.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need any experience?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No prior experience is needed for BLS. ACLS is designed for healthcare professionals who may encounter cardiovascular emergencies.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where is the skills check?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Orange County. Scheduling is flexible.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does it take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The online portion is self-paced (a few hours). The in-person skills check is about an hour for BLS, and about two hours for ACLS.',
      },
    },
    {
      '@type': 'Question',
      name: 'Who is this for?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'BLS is for anyone — healthcare professionals, students, individuals, companies. No prerequisites. ACLS is for healthcare professionals who manage cardiovascular emergencies.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will my employer accept this?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'AHA BLS Provider and ACLS Provider certifications are the standard for hospitals and clinics, and meet OSHA requirements.',
      },
    },
  ],
};

const blsCourseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'AHA BLS Provider Course',
  description: 'American Heart Association BLS Provider certification course. Hybrid format: online coursework plus in-person skills check.',
  provider: {
    '@type': 'Person',
    name: 'Sepi Reissmueller',
  },
  educationalCredentialAwarded: 'AHA BLS Provider eCard',
  courseMode: 'blended',
  locationCreated: {
    '@type': 'Place',
    name: 'Orange County, CA',
  },
};

const aclsCourseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'AHA ACLS Provider Course',
  description: 'American Heart Association ACLS Provider certification course. Hybrid format: online coursework plus in-person skills check.',
  provider: {
    '@type': 'Person',
    name: 'Sepi Reissmueller',
  },
  educationalCredentialAwarded: 'AHA ACLS Provider eCard',
  courseMode: 'blended',
  locationCreated: {
    '@type': 'Place',
    name: 'Orange County, CA',
  },
};
---

<BaseLayout
  title="BLS & ACLS Certification in Orange County — AHA Authorized"
  description="AHA-authorized BLS and ACLS certification in Orange County, CA. Hybrid course: online coursework plus in-person skills check. Taught by an ER nurse at UC Irvine Medical Center."
  schemas={[personSchema, websiteSchema, faqSchema, blsCourseSchema, aclsCourseSchema]}
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="max-w-3xl">
      <h1 class="text-4xl sm:text-5xl font-bold text-text leading-tight mb-6">
        BLS & ACLS Certification in <span class="text-primary">Orange County</span>
      </h1>
      <p class="text-lg text-text-muted leading-relaxed mb-4 max-w-2xl">
        Official American Heart Association BLS and ACLS courses. Hybrid format — complete the online coursework on your own time, then meet for an in-person skills check in Orange County.
      </p>
      <p class="text-lg text-text-muted leading-relaxed mb-8 max-w-2xl">
        Taught by Sepi Reissmueller, an ER nurse who manages the emergency department at UC Irvine Medical Center. Open to healthcare professionals, students, individuals, and companies.
      </p>
      <a
        href="#get-started"
        class="inline-flex items-center justify-center bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
      >
        Get Started
      </a>
    </div>
  </section>

  <!-- What the Courses Cover -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-text mb-10">What the Courses Cover</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div>
          <h3 class="text-xl font-semibold text-text mb-4">BLS Provider</h3>
          <ul class="space-y-3 text-text-muted">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Adult, child, and infant CPR
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              AED operation
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Choking relief
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              High-performance team CPR
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Bag-mask ventilation
            </li>
          </ul>
          <p class="text-sm text-text-muted mt-4">
            Official AHA BLS Provider course. You receive an AHA eCard on completion.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-text mb-4">ACLS Provider</h3>
          <ul class="space-y-3 text-text-muted">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Systematic approach to ACLS cases
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Recognition and management of cardiac arrest rhythms
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Airway management
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Pharmacology for ACLS
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">&#10003;</span>
              Team dynamics and communication
            </li>
          </ul>
          <p class="text-sm text-text-muted mt-4">
            Official AHA ACLS Provider course. You receive an AHA eCard on completion.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <h2 class="text-3xl font-bold text-text mb-10">How It Works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-4xl">
      <div class="text-center sm:text-left">
        <div class="text-3xl font-bold text-primary mb-3">1</div>
        <h3 class="font-semibold text-text mb-2">Online</h3>
        <p class="text-text-muted text-sm leading-relaxed">
          Complete the AHA coursework on your own time. Self-paced, takes a few hours.
        </p>
      </div>
      <div class="text-center sm:text-left">
        <div class="text-3xl font-bold text-primary mb-3">2</div>
        <h3 class="font-semibold text-text mb-2">Skills Check</h3>
        <p class="text-text-muted text-sm leading-relaxed">
          Meet in person in Orange County for a hands-on skills session. About an hour for BLS, about two hours for ACLS.
        </p>
      </div>
      <div class="text-center sm:text-left">
        <div class="text-3xl font-bold text-primary mb-3">3</div>
        <h3 class="font-semibold text-text mb-2">Certification</h3>
        <p class="text-text-muted text-sm leading-relaxed">
          Receive your AHA Provider eCard, valid for 2 years.
        </p>
      </div>
    </div>
  </section>

  <!-- About Sepi -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-text mb-6">About the Instructor</h2>
      <div class="max-w-3xl">
        <p class="text-text-muted leading-relaxed mb-4">
          Sepi Reissmueller is an ER nurse at UC Irvine Medical Center, where she manages the emergency department.
        </p>
        <p class="text-text-muted leading-relaxed">
          She is an American Heart Association authorized BLS and ACLS instructor.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <h2 class="text-3xl font-bold text-text mb-10">Common Questions</h2>
    <div class="space-y-6 max-w-3xl">
      <div>
        <h3 class="font-semibold text-text mb-2">Is this an official AHA course?</h3>
        <p class="text-text-muted leading-relaxed">
          Yes. These are official American Heart Association courses. You receive an AHA eCard on completion.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">How long does certification last?</h3>
        <p class="text-text-muted leading-relaxed">2 years.</p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">Do I need any experience?</h3>
        <p class="text-text-muted leading-relaxed">
          No prior experience is needed for BLS. ACLS is designed for healthcare professionals who may encounter cardiovascular emergencies.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">Where is the skills check?</h3>
        <p class="text-text-muted leading-relaxed">Orange County. Scheduling is flexible.</p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">How long does it take?</h3>
        <p class="text-text-muted leading-relaxed">
          The online portion is self-paced (a few hours). The in-person skills check is about an hour for BLS, and about two hours for ACLS.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">Who is this for?</h3>
        <p class="text-text-muted leading-relaxed">
          BLS is for anyone — healthcare professionals, students, individuals, companies. No prerequisites. ACLS is for healthcare professionals who manage cardiovascular emergencies.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">Will my employer accept this?</h3>
        <p class="text-text-muted leading-relaxed">
          AHA BLS Provider and ACLS Provider certifications are the standard for hospitals and clinics, and meet OSHA requirements.
        </p>
      </div>
    </div>
  </section>

  <!-- Get Started -->
  <section id="get-started" class="bg-surface py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-text mb-4">Get Started</h2>
        <p class="text-text-muted mb-8">
          Fill out the form below and I'll reach out to get you scheduled.
        </p>

        <iframe
          src="https://docs.google.com/forms/d/e/1FAIpQLSeBjF2ljhuaArycRJWcSDYdUtBlPrxaUhKI27uSEyo33cQkcg/viewform?embedded=true"
          width="100%"
          height="800"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          class="rounded-lg"
          title="Contact form"
          loading="lazy"
        >
          Loading…
        </iframe>
      </div>
    </div>
  </section>
</BaseLayout>
